import torch
from torch import nn
class Oscar(nn.Module):
    def __init__(self, threshold = 1.0, n = 2.0,per_channel = False, num_channels = None):
        super(Oscar, self).__init__()
        self.n = n
        if per_channel and num_channels is not None:
            self.threshold = nn.Parameter(torch.ones(num_channels)* threshold)
            self.per_channel = True
        else:
            self.threshold = nn.Parameter(torch.tensor(threshold)) if per_channel else threshold
            self.per_channel = False
    def forward(self, x):
        device = x.device
        if self.per_channel and isinstance(self.threshold, nn.Parameter):
            shape = [1, -1]+[1]*(x.dim() - 2)
            threshold = self.threshold.view(*shape)
        else:
            threshold = torch.tensor([self.threshold])
        n = torch.as_tensor(self.n, dtype = torch.float32, device = device)
        n_thresh = self.n ** threshold
        c = n_thresh - torch.log2(threshold + 1) - 1
        power_part = self.n ** x
        log_part = torch.log2(x+1) + 1 + c
        return torch.where(x <= threshold, power_part, log_part)

